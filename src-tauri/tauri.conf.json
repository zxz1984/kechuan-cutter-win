{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "可乐裁切",
  "version": "1.0.14",
  "identifier": "com.laozheng.cutter",
  "build": {
    "beforeDevCommand": "npx concurrently --kill-others-on-fail -n vite \"npm:dev\"",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "可乐裁切 v1.0.14",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.icns"
    ],
    "resources": [
      "../bin/ffmpeg-darwin-x64"
    ]
  }
}
